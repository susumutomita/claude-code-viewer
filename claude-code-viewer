def render_tree_html(tree, indent=0):
    if not tree:
        return ''
    html = ''
    for node in tree:
        pad = '  ' * indent
        if node['type'] == 'dir':
            html += f'{pad}<li><span class="dir">{node["name"]}/</span>\n'
            children = node.get('children')
            if children:
                html += f'{pad}  <ul>\n{render_tree_html(children, indent+2)}{pad}  </ul>\n'
            html += f'{pad}</li>\n'
        else:
            size = node.get('size', 0)
            sz = f'{size}B' if size < 1024 else f'{size//1024}KB'
            html += f'{pad}<li><span class="file">{node["name"]}</span> <span class="desc">{sz}</span></li>\n'
    return html


def generate_html(info):
    tree_html = render_tree_html(info['tree'])

    stack_badges = ''.join(
        f'<span class="badge badge-{s["color"]}">{s["name"]}</span> '
        for s in info['stack']
    )

    key_files_rows = ''.join(
        f'<tr><td><code class="inline-code">{f}</code></td></tr>'
        for f in info['key_files']
    )

    prompts_by_section = {}
    for p in info['prompts']:
        prompts_by_section.setdefault(p['section'], []).append(p['text'])

    prompts_html = ''
    for section, texts in prompts_by_section.items():
        prompts_html += f'<h4>{section}</h4>\n'
        for text in texts:
            prompts_html += f'''<div class="claude-box">
  <div style="position:relative" class="claude-prompt" onclick="copyPrompt(this)">
    {text}
    <button class="copy-btn">Copy</button>
  </div>
</div>\n'''

    return HTML_TEMPLATE.replace('{{PROJECT_NAME}}', info['name']) \
        .replace('{{STACK_BADGES}}', stack_badges) \
        .replace('{{FILE_TREE}}', tree_html) \
        .replace('{{KEY_FILES_ROWS}}', key_files_rows) \
        .replace('{{PROMPTS_HTML}}', prompts_html) \
        .replace('{{PROJECT_ROOT}}', info['root'])


