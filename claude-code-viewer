<script>
// ========== Chat ==========
let chatOpen=false;
function toggleChat(){chatOpen=!chatOpen;const p=document.getElementById('chatPanel'),f=document.getElementById('chatFab');p.style.display=chatOpen?'flex':'none';f.innerHTML=chatOpen?'&times;':'&#x1F916;';if(chatOpen){document.getElementById('chatInput').focus();scrollChat()}}
function scrollChat(){const m=document.getElementById('chatMessages');m.scrollTop=m.scrollHeight}
function addMessage(text,role){const m=document.getElementById('chatMessages'),d=document.createElement('div');d.className='chat-msg '+role;const b=document.createElement('div');b.className='chat-bubble';b.innerHTML=role==='bot'?renderMd(text):escHtml(text);d.appendChild(b);m.appendChild(d);scrollChat();return b}
function addTyping(){const m=document.getElementById('chatMessages'),d=document.createElement('div');d.className='chat-msg bot';d.id='typingMsg';d.innerHTML='<div class="chat-bubble"><div class="typing-indicator"><span></span><span></span><span></span></div></div>';m.appendChild(d);scrollChat()}
function removeTyping(){const e=document.getElementById('typingMsg');if(e)e.remove()}
function escHtml(s){const d=document.createElement('div');d.textContent=s;return d.innerHTML}
function renderMd(t){return t.replace(/```(\w*)\n([\s\S]*?)```/g,'<pre><code>$2</code></pre>').replace(/`([^`]+)`/g,'<code class="inline-code">$1</code>').replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>')}
async function sendChat(prefill){const input=document.getElementById('chatInput'),q=prefill||input.value.trim();if(!q)return;input.value='';if(!chatOpen)toggleChat();addMessage(q,'user');addTyping();try{const r=await fetch('/api/ask',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({question:q,context:''})});removeTyping();if(r.ok){const d=await r.json();addMessage(d.answer||'No response.','bot')}else{const e=await r.json().catch(()=>({}));addMessage('Error: '+(e.error||r.statusText),'bot')}}catch(e){removeTyping();addMessage('サーバーに接続できません。','bot')}}

// ========== Context Menu ==========
let selectedText='';
document.addEventListener('contextmenu',e=>{const sel=window.getSelection().toString().trim();if(!sel)return;e.preventDefault();selectedText=sel;const menu=document.getElementById('contextMenu');menu.style.display='block';let x=e.clientX,y=e.clientY;if(x+menu.offsetWidth>window.innerWidth)x=window.innerWidth-menu.offsetWidth-8;if(y+menu.offsetHeight>window.innerHeight)y=window.innerHeight-menu.offsetHeight-8;menu.style.left=x+'px';menu.style.top=y+'px'});
document.addEventListener('click',()=>{document.getElementById('contextMenu').style.display='none'});
document.getElementById('ctxAsk').addEventListener('click',()=>sendChat('「'+selectedText+'」について詳しく教えて'));
document.getElementById('ctxExplain').addEventListener('click',()=>sendChat('以下を解説して:\n'+selectedText));
document.getElementById('ctxDeep').addEventListener('click',()=>sendChat('「'+selectedText+'」に関連するソースコードを読んで実装の詳細を教えて'));
document.getElementById('ctxCopy').addEventListener('click',()=>{navigator.clipboard.writeText(selectedText);showToast('Copied!')});

// ========== Ask buttons on prompts ==========
document.querySelectorAll('.claude-prompt').forEach(el=>{const a=document.createElement('button');a.className='ask-btn';a.textContent='Ask';a.addEventListener('click',e=>{e.stopPropagation();sendChat(el.textContent.replace('Copy','').replace('Ask','').trim())});el.appendChild(a)});

// ========== File Reader ==========
async function loadFile(){const input=document.getElementById('filePathInput'),path=input.value.trim();if(!path)return;const container=document.getElementById('fileContent');container.innerHTML='<pre style="color:var(--text-muted);padding:20px">Loading...</pre>';try{const r=await fetch('/api/file?path='+encodeURIComponent(path));if(r.ok){const d=await r.json();container.innerHTML='<pre><code>'+escHtml(d.content)+'</code></pre>'}else{const e=await r.json().catch(()=>({}));container.innerHTML='<pre style="color:var(--accent-red);padding:20px">Error: '+(e.error||'Not found')+'</pre>'}}catch(e){container.innerHTML='<pre style="color:var(--accent-red);padding:20px">Failed to connect</pre>'}}
// Click on file tree to open
document.querySelectorAll('.file-tree .file').forEach(el=>{el.style.cursor='pointer';el.addEventListener('click',()=>{let path='';let node=el.closest('li');const parts=[el.textContent];while(node.parentElement&&node.parentElement.closest('li')){node=node.parentElement.closest('li');const dir=node.querySelector(':scope > .dir');if(dir)parts.unshift(dir.textContent.replace('/',''))}document.getElementById('filePathInput').value=parts.join('/');loadFile();document.getElementById('file-reader').scrollIntoView({behavior:'smooth'})})});

// ========== Utils ==========
function toggleCollapsible(h){h.parentElement.classList.toggle('open')}
function copyPrompt(el){navigator.clipboard.writeText(el.textContent.replace('Copy','').replace('Ask','').trim()).then(()=>showToast('Copied!'))}
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),1500)}
const navLinks=document.querySelectorAll('.nav-link');
const observer=new IntersectionObserver(entries=>{entries.forEach(entry=>{if(entry.isIntersecting){navLinks.forEach(l=>l.classList.remove('active'));const link=document.querySelector('.nav-link[href="#'+entry.target.id+'"]');if(link)link.classList.add('active')}})},{rootMargin:'-20% 0px -70% 0px'});
document.querySelectorAll('h2[id],h1[id]').forEach(s=>observer.observe(s));
function filterNav(){const q=document.getElementById('searchInput').value.toLowerCase();navLinks.forEach(l=>{l.style.display=l.textContent.toLowerCase().includes(q)||q===''?'block':'none'})}
</script>
</body>
</html>'''


# ─────────────────────────────────────────────
# HTTP Server
# ─────────────────────────────────────────────

class ViewerHandler(http.server.BaseHTTPRequestHandler):
    project_root = '.'
    html_cache = ''

    def do_GET(self):
        if self.path == '/' or self.path == '/index.html':
            body = self.__class__.html_cache.encode('utf-8')
            self.send_response(200)
            self.send_header('Content-Type', 'text/html; charset=utf-8')
            self.send_header('Content-Length', str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        elif self.path.startswith('/api/file'):
            self.handle_file_read()
        else:
            self.send_error(404)

    def do_POST(self):
        if self.path == '/api/ask':
            self.handle_ask()
        else:
            self.send_json(404, {'error': 'Not found'})

    def handle_ask(self):
        body = self.rfile.read(int(self.headers.get('Content-Length', 0)))
        data = json.loads(body)
        question = data.get('question', '')
        context = data.get('context', '')
        if not question:
            self.send_json(400, {'error': 'question is required'})
            return
        prompt = question
        if context:
            prompt = f"{context}\n\n{question}"
        try:
            result = subprocess.run(
                ['claude', '-p', '--output-format', 'text', prompt],
                capture_output=True, text=True, timeout=120,
                cwd=self.__class__.project_root,
            )
            answer = result.stdout.strip()
            if result.returncode != 0 and not answer:
                answer = result.stderr.strip() or 'Error from Claude Code.'
            self.send_json(200, {'answer': answer})
        except subprocess.TimeoutExpired:
            self.send_json(504, {'error': 'Timed out (120s)'})
        except FileNotFoundError:
            self.send_json(500, {'error': '`claude` CLI not found.'})
        except Exception as e:
            self.send_json(500, {'error': str(e)})

    def handle_file_read(self):
        from urllib.parse import urlparse, parse_qs
        qs = parse_qs(urlparse(self.path).query)
        rel_path = qs.get('path', [''])[0]
        if not rel_path:
            self.send_json(400, {'error': 'path is required'})
            return
        # Security: prevent path traversal outside project root
        root = Path(self.__class__.project_root).resolve()
        target = (root / rel_path).resolve()
        if not str(target).startswith(str(root)):
            self.send_json(403, {'error': 'Access denied'})
            return
        if not target.is_file():
            self.send_json(404, {'error': f'File not found: {rel_path}'})
            return
        try:
            content = target.read_text(errors='replace')
            # Limit to 500 lines for display
            lines = content.split('\n')
            if len(lines) > 500:
                content = '\n'.join(lines[:500]) + f'\n\n... ({len(lines) - 500} more lines)'
            self.send_json(200, {'content': content, 'path': str(target.relative_to(root))})
        except Exception as e:
            self.send_json(500, {'error': str(e)})

    def send_json(self, status, data):
        body = json.dumps(data, ensure_ascii=False).encode('utf-8')
        self.send_response(status)
        self.send_header('Content-Type', 'application/json; charset=utf-8')
        self.send_header('Content-Length', str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, format, *args):
        if '/api/' in (args[0] if args else ''):
            super().log_message(format, *args)


def main():
    parser = argparse.ArgumentParser(
        description='claude-code-viewer — Browse any codebase with Claude Code AI',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='Examples:\n  claude-code-viewer\n  claude-code-viewer /path/to/project\n  claude-code-viewer --port 3000',
    )
    parser.add_argument('project_dir', nargs='?', default='.', help='Project directory (default: current dir)')
    parser.add_argument('--port', '-p', type=int, default=8080, help='Port (default: 8080)')
    parser.add_argument('--no-open', action='store_true', help='Do not auto-open browser')
    args = parser.parse_args()

    project_dir = Path(args.project_dir).resolve()
    if not project_dir.is_dir():
        print(f'Error: {project_dir} is not a directory')
        sys.exit(1)

    print(f'Scanning {project_dir} ...')
    info = scan_project(project_dir)
    print(f'  Found {len(info["stack"])} tech stack items, {len(info["key_files"])} key files')

    ViewerHandler.project_root = str(project_dir)
    ViewerHandler.html_cache = generate_html(info)

    print(f'\n  Project:  {info["name"]}')
    print(f'  URL:      http://localhost:{args.port}')
    print(f'  Chat:     POST /api/ask → claude -p')
    print(f'  Files:    GET /api/file?path=...')
    print(f'\n  Press Ctrl+C to stop.\n')

    if not args.no_open:
        import webbrowser
        webbrowser.open(f'http://localhost:{args.port}')

    server = http.server.HTTPServer(('', args.port), ViewerHandler)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print('\nStopped.')
        server.server_close()


if __name__ == '__main__':
    main()
