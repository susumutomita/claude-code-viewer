IGNORE_DIRS = {
    'node_modules', '.git', '__pycache__', '.venv', 'venv', 'dist', 'build',
    '.next', '.nuxt', '.cache', 'coverage', '.tox', '.mypy_cache', '.pytest_cache',
    'cdk.out', '.aws-sam', '.serverless', 'target', 'vendor', 'Pods',
}
IGNORE_FILES = {'.DS_Store', 'Thumbs.db', 'package-lock.json', 'yarn.lock', 'pnpm-lock.yaml'}

CODE_EXTENSIONS = {
    '.py', '.js', '.ts', '.tsx', '.jsx', '.java', '.go', '.rs', '.rb', '.php',
