    '.sh', '.bash', '.zsh', '.fish', '.ps1',
    '.md', '.mdx', '.rst', '.txt',
    '.dockerfile', '.Makefile',
}

def scan_project(root):
    """Scan project and return structured info."""
    root = Path(root).resolve()
    project_name = root.name

    # Detect project type
    markers = detect_markers(root)

    # Build file tree (max 3 levels deep for overview)
    tree = build_tree(root, root, max_depth=4)

    # Detect key files
    key_files = find_key_files(root)

    # Generate suggested prompts
    prompts = generate_prompts(root, markers, key_files)

    # Detect tech stack
    stack = detect_stack(markers)

    return {
        'name': project_name,
        'root': str(root),
        'markers': markers,
        'tree': tree,
        'key_files': key_files,
        'prompts': prompts,
        'stack': stack,
    }


def detect_markers(root):
    markers = {}
    checks = {
        'package.json': 'node',
        'tsconfig.json': 'typescript',
        'requirements.txt': 'python',
        'pyproject.toml': 'python',
        'Pipfile': 'python',
        'setup.py': 'python',
        'go.mod': 'golang',
        'Cargo.toml': 'rust',
        'Gemfile': 'ruby',
        'pom.xml': 'java_maven',
        'build.gradle': 'java_gradle',
        'docker-compose.yml': 'docker',
        'docker-compose.yaml': 'docker',
        'Dockerfile': 'docker',
        'cdk.json': 'aws_cdk',
        'serverless.yml': 'serverless_framework',
        'terraform.tf': 'terraform',
        'angular.json': 'angular',
        'next.config.js': 'nextjs',
        'next.config.ts': 'nextjs',
        'nuxt.config.ts': 'nuxt',
        'vite.config.ts': 'vite',
        'webpack.config.js': 'webpack',
        '.github/workflows': 'github_actions',
        'Makefile': 'makefile',
        'CLAUDE.md': 'claude_code',
    }
    for file, marker in checks.items():
        p = root / file
        if p.exists():
            markers[marker] = str(p)
    # Also check subdirectories
    for d in root.iterdir():
        if d.is_dir() and d.name not in IGNORE_DIRS:
            for file, marker in checks.items():
                if (d / file).exists():
                    markers[marker] = str(d / file)
    return markers


def build_tree(path, root, max_depth=4, current_depth=0):
    if current_depth >= max_depth:
        return None
    items = []
    try:
        entries = sorted(path.iterdir(), key=lambda e: (not e.is_dir(), e.name.lower()))
    except PermissionError:
        return items
    for entry in entries:
        if entry.name.startswith('.') and entry.name not in ('.github', '.env.example'):
            continue
        if entry.name in IGNORE_DIRS or entry.name in IGNORE_FILES:
            continue
        node = {'name': entry.name, 'path': str(entry.relative_to(root))}
        if entry.is_dir():
            node['type'] = 'dir'
            children = build_tree(entry, root, max_depth, current_depth + 1)
            if children is not None:
                node['children'] = children
        else:
            node['type'] = 'file'
            ext = entry.suffix.lower()
            node['ext'] = ext
            try:
                size = entry.stat().st_size
                node['size'] = size
            except OSError:
                node['size'] = 0
        items.append(node)
    return items


def find_key_files(root):
    """Find important files for understanding the project."""
    key_patterns = [
        'README*', 'CLAUDE.md', 'CONTRIBUTING*', 'ARCHITECTURE*',
        'Makefile', 'Dockerfile', 'docker-compose*',
        'package.json', 'tsconfig.json', 'cdk.json',
        'requirements.txt', 'pyproject.toml', 'setup.py', 'setup.cfg',
        'go.mod', 'Cargo.toml', 'Gemfile', 'pom.xml',
    ]
    found = []
    for pattern in key_patterns:
        for match in root.glob(pattern):
            if match.is_file():
                found.append(str(match.relative_to(root)))
    # Also find entry points
    for pattern in ['**/main.py', '**/app.py', '**/index.ts', '**/index.js', '**/main.go', '**/main.rs']:
        for match in root.glob(pattern):
            rel = str(match.relative_to(root))
            if not any(ig in rel for ig in IGNORE_DIRS):
                found.append(rel)
    return sorted(set(found))


def detect_stack(markers):
    stack = []
    mapping = {
        'node': ('Node.js', 'green'),
        'typescript': ('TypeScript', 'blue'),
        'python': ('Python', 'green'),
        'golang': ('Go', 'blue'),
        'rust': ('Rust', 'orange'),
        'ruby': ('Ruby', 'red'),
        'java_maven': ('Java (Maven)', 'orange'),
        'java_gradle': ('Java (Gradle)', 'orange'),
        'aws_cdk': ('AWS CDK', 'blue'),
        'docker': ('Docker', 'blue'),
        'angular': ('Angular', 'red'),
        'nextjs': ('Next.js', 'purple'),
        'nuxt': ('Nuxt', 'green'),
        'vite': ('Vite', 'purple'),
        'serverless_framework': ('Serverless Framework', 'orange'),
        'terraform': ('Terraform', 'purple'),
        'github_actions': ('GitHub Actions', 'blue'),
    }
    for key, (name, color) in mapping.items():
        if key in markers:
            stack.append({'name': name, 'color': color})
    return stack


