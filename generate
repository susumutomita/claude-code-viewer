#!/usr/bin/env python3
"""
Deep code documentation generator with Claude Code integration.

This script:
1. Scans the project structure
2. Calls `claude -p` to deeply analyze each major component
3. Generates a complete static site with architecture docs
4. Serves it with chat widget + right-click → Ask Claude Code

Every run is a FULL REBUILD — no incremental updates, no stale docs.
"""
import subprocess
import json
import os
import sys
import argparse
import re
import time
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor, as_completed

# ─────────────────────────────────────────────
# Config
# ─────────────────────────────────────────────

IGNORE_DIRS = {
    'node_modules', '.git', '__pycache__', '.venv', 'venv', 'dist', 'build',
    '.next', '.nuxt', '.cache', 'coverage', '.tox', '.mypy_cache', '.pytest_cache',
    'cdk.out', '.aws-sam', '.serverless', 'target', 'vendor', 'Pods',
    '.terraform', '.angular',
}
IGNORE_FILES = {'.DS_Store', 'Thumbs.db', 'package-lock.json', 'yarn.lock', 'pnpm-lock.yaml'}

CODE_EXTS = {
    '.py', '.js', '.ts', '.tsx', '.jsx', '.java', '.go', '.rs', '.rb', '.php',
    '.swift', '.kt', '.scala', '.cs', '.cpp', '.c', '.h',
    '.vue', '.svelte', '.astro',
    '.sql', '.graphql', '.proto', '.tf', '.hcl',
    '.yaml', '.yml', '.json', '.toml',
    '.sh', '.bash', '.dockerfile',
}

OUTPUT_DIR_NAME = '.codewiki'


# ─────────────────────────────────────────────
# Step 1: Scan project
# ─────────────────────────────────────────────

def scan_project(root):
    root = Path(root).resolve()
    tree = build_tree(root, root, max_depth=5)
    key_files = find_key_files(root)
    dirs = find_major_dirs(root)
    stack = detect_stack(root)
    stats = count_files(root)
    return {
        'name': root.name,
        'root': str(root),
        'tree': tree,
        'key_files': key_files,
        'major_dirs': dirs,
        'stack': stack,
        'stats': stats,
    }


def build_tree(path, root, max_depth=5, depth=0):
    if depth >= max_depth:
        return None
    items = []
    try:
        entries = sorted(path.iterdir(), key=lambda e: (not e.is_dir(), e.name.lower()))
    except PermissionError:
        return items
    for entry in entries:
        if entry.name.startswith('.') and entry.name not in ('.github',):
            continue
        if entry.name in IGNORE_DIRS or entry.name in IGNORE_FILES:
            continue
        node = {'name': entry.name, 'path': str(entry.relative_to(root))}
        if entry.is_dir():
            node['type'] = 'dir'
            children = build_tree(entry, root, max_depth, depth + 1)
            if children is not None:
                node['children'] = children
        else:
            node['type'] = 'file'
            node['ext'] = entry.suffix.lower()
        items.append(node)
    return items


def find_key_files(root):
    patterns = [
        'README*', 'CLAUDE.md', 'ARCHITECTURE*', 'CONTRIBUTING*',
        'Makefile', 'Dockerfile', 'docker-compose*',
        'package.json', 'tsconfig.json', 'cdk.json',
        'requirements.txt', 'pyproject.toml', 'setup.py',
        'go.mod', 'Cargo.toml', 'Gemfile', 'pom.xml', 'build.gradle',
        'serverless.yml', 'serverless.yaml',
        'angular.json', 'next.config.*', 'vite.config.*',
    ]
    found = []
    for p in patterns:
        for m in root.glob(p):
            if m.is_file():
                found.append(str(m.relative_to(root)))
    return sorted(set(found))


def find_major_dirs(root):
    """Find directories that likely contain important code."""
    dirs = []
    for entry in sorted(root.iterdir()):
        if not entry.is_dir():
            continue
        if entry.name.startswith('.') or entry.name in IGNORE_DIRS:
            continue
        # Count code files
        code_count = sum(1 for f in entry.rglob('*')
                         if f.is_file() and f.suffix.lower() in CODE_EXTS
                         and not any(ig in str(f) for ig in IGNORE_DIRS))
        if code_count > 0:
            dirs.append({'name': entry.name, 'path': str(entry.relative_to(root)), 'file_count': code_count})
    # Also check src/, lib/, app/ etc inside subdirs
    for sub in ['src', 'lib', 'app', 'pkg', 'cmd', 'internal', 'api', 'services']:
        for match in root.rglob(sub):
            if match.is_dir() and not any(ig in str(match) for ig in IGNORE_DIRS):
                rel = str(match.relative_to(root))
                if rel not in [d['path'] for d in dirs]:
                    code_count = sum(1 for f in match.rglob('*')
                                     if f.is_file() and f.suffix.lower() in CODE_EXTS
                                     and not any(ig in str(f) for ig in IGNORE_DIRS))
                    if code_count > 2:
                        dirs.append({'name': rel, 'path': rel, 'file_count': code_count})
    return sorted(dirs, key=lambda d: d['file_count'], reverse=True)[:15]


def detect_stack(root):
    checks = {
        'package.json': 'Node.js', 'tsconfig.json': 'TypeScript',
        'requirements.txt': 'Python', 'pyproject.toml': 'Python',
        'go.mod': 'Go', 'Cargo.toml': 'Rust', 'Gemfile': 'Ruby',
        'pom.xml': 'Java', 'build.gradle': 'Java',
        'cdk.json': 'AWS CDK', 'serverless.yml': 'Serverless',
        'terraform.tf': 'Terraform', 'docker-compose.yml': 'Docker',
        'Dockerfile': 'Docker', 'angular.json': 'Angular',
    }
    found = set()
    for f, name in checks.items():
        if (root / f).exists():
            found.add(name)
        for sub in root.iterdir():
            if sub.is_dir() and sub.name not in IGNORE_DIRS and (sub / f).exists():
                found.add(name)
    return sorted(found)


def count_files(root):
    total = 0
    by_ext = {}
    for f in root.rglob('*'):
        if not f.is_file():
            continue
        if any(ig in str(f) for ig in IGNORE_DIRS):
            continue
        total += 1
        ext = f.suffix.lower() or '(no ext)'
        by_ext[ext] = by_ext.get(ext, 0) + 1
    top = sorted(by_ext.items(), key=lambda x: x[1], reverse=True)[:10]
    return {'total': total, 'top_extensions': top}


# ─────────────────────────────────────────────
# Step 2: Deep analysis with Claude Code
# ─────────────────────────────────────────────

def claude_ask(prompt, cwd, timeout=180):
    """Call claude -p and return the answer."""
    try:
        result = subprocess.run(
            ['claude', '-p', '--output-format', 'text', prompt],
            capture_output=True, text=True, timeout=timeout, cwd=cwd,
        )
        return result.stdout.strip() or result.stderr.strip() or '(no response)'
    except subprocess.TimeoutExpired:
        return '(analysis timed out)'
    except FileNotFoundError:
        print('ERROR: `claude` CLI not found. Install Claude Code first.')
        sys.exit(1)


def analyze_project(info, verbose=False):
    """Run multiple Claude Code analyses in parallel."""
    root = info['root']
    analyses = {}
    prompts = {}

    # 1. Overall architecture
    prompts['overview'] = (
        'このプロジェクトの全体像を解説してください。以下を含めて:\n'
        '- プロジェクトの目的と概要 (2-3文)\n'
        '- アーキテクチャの概要\n'
        '- 主要コンポーネントとその関係\n'
        '- 使われている技術スタックとその選定理由\n'
        '- データフロー\n\n'
        'マークダウンで回答してください。見出しは ## から始めてください。'
    )

    # 2. Directory-by-directory analysis
    for d in info['major_dirs'][:8]:
        prompts[f'dir_{d["path"]}'] = (
            f'ディレクトリ `{d["path"]}/` の中身を読んで詳しく解説してください:\n'
            f'- このディレクトリの目的と役割\n'
            f'- 主要ファイルとその機能\n'
            f'- 重要な関数・クラス・パターン\n'
            f'- 他のディレクトリとの依存関係\n\n'
            f'マークダウンで回答してください。見出しは ### から始めてください。'
        )

    # 3. Key patterns & design decisions
    prompts['patterns'] = (
        'このプロジェクトで使われている重要な設計パターン、アーキテクチャパターンを分析してください:\n'
        '- デザインパターン (Factory, Strategy, etc.)\n'
        '- アーキテクチャパターン (MVC, Microservices, etc.)\n'
        '- セキュリティパターン\n'
        '- エラーハンドリング戦略\n'
        '- テスト戦略\n\n'
        'マークダウンで回答してください。見出しは ## から始めてください。'
    )

    # 4. Dependency & API analysis
    prompts['dependencies'] = (
        'このプロジェクトの依存関係とAPIを分析してください:\n'
        '- 主要な外部依存ライブラリとその用途\n'
        '- 内部モジュール間の依存関係\n'
        '- 公開API/エンドポイント (あれば)\n'
        '- 設定ファイルの構造\n\n'
        'マークダウンで回答してください。見出しは ## から始めてください。'
    )

    # 5. Getting started / developer guide
    prompts['devguide'] = (
        'このプロジェクトの開発者ガイドを書いてください:\n'
        '- セットアップ手順\n'
        '- ビルド・テストの方法\n'
        '- デプロイ方法\n'
        '- よくあるトラブルシューティング\n'
        '- コントリビューション方法\n\n'
        'READMEやスクリプトを読んで、実際のコマンドを含めてください。\n'
        'マークダウンで回答してください。見出しは ## から始めてください。'
    )

    total = len(prompts)
    print(f'\n  Running {total} analyses with Claude Code...\n')

    def run_one(key, prompt):
        if verbose:
            label = key[:40]
            print(f'    [{label}] analyzing...')
        t0 = time.time()
        result = claude_ask(prompt, root)
        elapsed = time.time() - t0
        print(f'    [{key[:40]}] done ({elapsed:.0f}s)')
        return key, result

    # Run up to 3 in parallel (avoid overwhelming claude CLI)
    with ThreadPoolExecutor(max_workers=3) as pool:
        futures = {pool.submit(run_one, k, p): k for k, p in prompts.items()}
        for future in as_completed(futures):
            key, result = future.result()
            analyses[key] = result

    return analyses


# ─────────────────────────────────────────────
# Step 3: Generate HTML
# ─────────────────────────────────────────────

def md_to_html(md):
    """Minimal markdown to HTML conversion."""
    lines = md.split('\n')
    html_parts = []
    in_code = False
    code_buf = []

    for line in lines:
        if line.startswith('```'):
            if in_code:
                html_parts.append('<pre><code>' + esc(('\n'.join(code_buf))) + '</code></pre>')
                code_buf = []
                in_code = False
            else:
                in_code = True
            continue
        if in_code:
            code_buf.append(line)
            continue

        # Headers
        if line.startswith('#### '):
            html_parts.append(f'<h4>{esc(line[5:])}</h4>')
        elif line.startswith('### '):
            html_parts.append(f'<h3>{esc(line[4:])}</h3>')
        elif line.startswith('## '):
            html_parts.append(f'<h2>{esc(line[3:])}</h2>')
        elif line.startswith('# '):
            html_parts.append(f'<h3>{esc(line[2:])}</h3>')
        elif line.startswith('- ') or line.startswith('* '):
            html_parts.append(f'<li>{inline_md(line[2:])}</li>')
        elif re.match(r'^\d+\. ', line):
            stripped = re.sub(r'^\d+\. ', '', line)
            html_parts.append(f'<li>{inline_md(stripped)}</li>')
        elif line.strip() == '':
            html_parts.append('')
        else:
            html_parts.append(f'<p>{inline_md(line)}</p>')

    if in_code and code_buf:
        html_parts.append('<pre><code>' + esc('\n'.join(code_buf)) + '</code></pre>')

    return '\n'.join(html_parts)


def inline_md(text):
    text = esc(text)
    text = re.sub(r'`([^`]+)`', r'<code class="inline-code">\1</code>', text)
    text = re.sub(r'\*\*([^*]+)\*\*', r'<strong>\1</strong>', text)
    text = re.sub(r'\*([^*]+)\*', r'<em>\1</em>', text)
    return text


def esc(s):
    return s.replace('&', '&amp;').replace('<', '&lt;').replace('>', '&gt;')


def render_tree_html(tree, indent=0):
    if not tree:
        return ''
    html = ''
    for node in tree:
        if node['type'] == 'dir':
            html += f'<li><span class="dir">{esc(node["name"])}/</span>\n'
            children = node.get('children')
            if children:
                html += f'<ul>{render_tree_html(children, indent+1)}</ul>\n'
            html += '</li>\n'
        else:
            html += f'<li><span class="file">{esc(node["name"])}</span></li>\n'
    return html


def generate_site(info, analyses, output_dir):
    """Generate the complete static site."""
    output_dir = Path(output_dir)
    output_dir.mkdir(parents=True, exist_ok=True)

    # Build navigation entries from analyses
    nav_items = []
    nav_items.append(('overview', 'Overview', 'overview'))
    for d in info['major_dirs'][:8]:
        key = f'dir_{d["path"]}'
        if key in analyses:
            nav_items.append((key, d['name'], key.replace('/', '-').replace('.', '-')))
    nav_items.append(('patterns', 'Design Patterns', 'patterns'))
    nav_items.append(('dependencies', 'Dependencies & API', 'dependencies'))
    nav_items.append(('devguide', 'Developer Guide', 'devguide'))

    # Render nav
    nav_html = ''
    nav_html += '<div class="nav-section">Documentation</div>\n'
    for key, label, anchor in nav_items:
        nav_html += f'<a class="nav-link" href="#{anchor}">{esc(label)}</a>\n'
    nav_html += '<div class="nav-section">Explore</div>\n'
    nav_html += '<a class="nav-link" href="#structure">File Tree</a>\n'
    nav_html += '<a class="nav-link" href="#file-reader">File Reader</a>\n'

    # Render content sections
    sections_html = ''
    for key, label, anchor in nav_items:
        content = analyses.get(key, '')
        sections_html += f'<h2 id="{anchor}">{esc(label)}</h2>\n'
        sections_html += f'<div class="section-content">{md_to_html(content)}</div>\n'
        # Add suggested follow-up prompts
        sections_html += f'''<div class="claude-box">
  <div style="position:relative" class="claude-prompt" onclick="copyPrompt(this)">
    「{esc(label)}」セクションの内容をさらに深掘りして。具体的なコードを引用して説明して。
    <button class="copy-btn">Copy</button>
  </div>
</div>\n'''

    # Stack badges
    stack_html = ' '.join(f'<span class="badge badge-blue">{esc(s)}</span>' for s in info['stack'])

    # Stats
    stats = info['stats']
    stats_html = f'{stats["total"]} files'

    # Tree
    tree_html = render_tree_html(info['tree'])

    # Timestamp
    ts = time.strftime('%Y-%m-%d %H:%M:%S')

    html = HTML_TEMPLATE \
        .replace('{{PROJECT_NAME}}', esc(info['name'])) \
        .replace('{{PROJECT_ROOT}}', esc(info['root'])) \
        .replace('{{NAV_HTML}}', nav_html) \
        .replace('{{SECTIONS_HTML}}', sections_html) \
        .replace('{{STACK_BADGES}}', stack_html) \
        .replace('{{STATS}}', stats_html) \
        .replace('{{FILE_TREE}}', tree_html) \
        .replace('{{TIMESTAMP}}', ts)

    index_path = output_dir / 'index.html'
    index_path.write_text(html, encoding='utf-8')
    return index_path


